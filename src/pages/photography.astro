---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="LKT | Photography"
  currentPath="/photography"
  description="Photography page for Ludovic K. Tuncay."
>
  <section class="page-container pt-16">
    <div class="max-w-[44rem] space-y-6">
      <h1 class="display-title accent-glow">Photography</h1>
      <p class="body-copy">
        This page is scaffolded so the navigation works cleanly. The album system can now be added
        on top of the same typography, layout, and interaction tokens defined for the home page.
      </p>
    </div>
  </section>
</BaseLayout>
